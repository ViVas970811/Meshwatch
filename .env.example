# Kaggle API (for IEEE-CIS dataset download)
# Get from https://www.kaggle.com/settings -> "Create New API Token"
# Also accept rules at https://www.kaggle.com/c/ieee-fraud-detection/rules
#
# Pick ONE of:
#   A. New-format Bearer token (starts with "KGAT_"):
#      KAGGLE_API_TOKEN=KGAT_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   B. Legacy username + key (kaggle.json format):
#      KAGGLE_USERNAME=your_kaggle_username
#      KAGGLE_KEY=your_kaggle_api_key
#   C. Place kaggle.json at ~/.kaggle/kaggle.json (no env vars needed).
#
# KAGGLE_API_TOKEN takes precedence if both are set.
# KAGGLE_API_TOKEN=
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Data paths (relative to project root, or absolute)
FRAUD_DATA_RAW_DIR=data/raw
FRAUD_DATA_PROCESSED_DIR=data/processed
FRAUD_DATA_SPLITS_DIR=data/splits
FRAUD_DATA_GRAPHS_DIR=data/graphs

# Dataset config
FRAUD_DATASET_SLUG=ieee-fraud-detection
FRAUD_USE_SUBSET=false
FRAUD_SUBSET_SIZE=200000

# Logging
FRAUD_LOG_LEVEL=INFO
FRAUD_LOG_JSON=true

# Random seed
FRAUD_RANDOM_SEED=42

# Phase 4+ (populated in later phases)
# MLFLOW_TRACKING_URI=http://localhost:5000
# REDIS_URL=redis://localhost:6379/0
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=changeme
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# OLLAMA_BASE_URL=http://localhost:11434
